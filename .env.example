# ─── Image Sourcing (free APIs — get one of these) ───
# Pexels (recommended): https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-key-here

# Unsplash: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-key-here

# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-key-here

# ─── GPT-4o Baseline (OpenAI) ───
OPENAI_API_KEY=sk-your-key-here

# ─── Experiment Tracking (optional) ───
WANDB_API_KEY=your-wandb-key
WANDB_PROJECT=wayfair-catalog-ai

# ─── Hugging Face (optional) ───
HF_TOKEN=hf_your-token-here

# ─── Paths ───
DATA_DIR=./data
OUTPUT_DIR=./outputs
